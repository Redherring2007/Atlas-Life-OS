-    async function forgetAllowed(name) {
+    function forgetAllowed(name) {
       const key = allowedKeys[name];
       if (!key) return;
       localStorage.removeItem(key);
     }
 
+    async function hasRememberedAccess(name) {
+      const state = await permissionState(name);
+      if (state === "granted") {
+        rememberAllowed(name);
+        return true;
+      }
+      if (state === "denied") {
+        forgetAllowed(name);
+        return false;
+      }
+      return localStorage.getItem(allowedKeys[name]) === "1";
+    }
